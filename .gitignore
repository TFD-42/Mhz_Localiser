# macOS
.DS_Store

# Build outputs (artifacts/ is whitelisted below for the published binaries)
**/dist/
*.apk
*.aab
*.fap
!artifacts/*.apk
!artifacts/*.fap

# UFBT / Flipper SDK local artifacts
.ufbt/

# Node / Capacitor
node_modules/
.cap/

# Android Studio / Gradle scaffolding (regenerated by `npx cap add android`)
android/.gradle/
android/local.properties
android/build/
android/app/build/
android/capacitor-cordova-android-plugins/
*.iml

# IDE
.vscode/
.idea/

# Logs
*.log
